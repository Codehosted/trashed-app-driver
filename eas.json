{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://trashed.ngrok.app",
        "WEB_APP_URL": "https://trashed-app-driver.vercel.app/"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://trashed-staging.vercel.app",
        "WEB_APP_URL": "https://trashed-app-driver.vercel.app/"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "API_BASE_URL": "https://trashed.app",
        "WEB_APP_URL": "https://trashed-app-driver.vercel.app/"
      }
    }
  },
  "submit": {
    "production": {
      "env": {
        "API_BASE_URL": "https://trashed.app",
        "WEB_APP_URL": "https://trashed-app-driver.vercel.app/"
      }
    }
  }
}
