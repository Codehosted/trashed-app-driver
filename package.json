{
  "name": "trashed-app-for-drivers",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "android": "expo run:android",
    "ios": "IOS_SIMULATOR_DEVICE_NAME=\"iPhone 12 Pro Max\" expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios:dev": "NODE_ENV=development eas build --profile development --platform ios",
    "build:ios:dev:local": "NODE_ENV=development eas build --profile development --platform ios --local",
    "build:ios:prod:local": "NODE_ENV=production eas build --profile production --platform ios --local"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.15",
    "@react-navigation/native-stack": "^7.2.0",
    "@types/react-native-web": "^0.19.2",
    "expo": "^54.0.0",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.11",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.14",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.8.3"
  }
