{
  "name": "trashed-app-for-drivers",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "IOS_SIMULATOR_DEVICE_NAME=\"iPhone 12 Pro Max\" expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios:dev": "NODE_ENV=development eas build --profile development --platform ios",
    "build:ios:dev:local": "NODE_ENV=development eas build --profile development --platform ios --local",
    "build:ios:prod:local": "NODE_ENV=production eas build --profile production --platform ios --local"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.15",
    "@react-navigation/native-stack": "^7.2.0",
    "@types/react-native-web": "^0.19.2",
    "expo": "^52.0.0",
    "expo-application": "~6.0.1",
    "expo-constants": "~17.0.4",
    "expo-dev-client": "~5.0.1",
    "expo-device": "~7.0.3",
    "expo-linking": "~7.0.2",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.0",
    "expo-splash-screen": "~0.29.11",
    "expo-status-bar": "~2.0.1",
    "firebase": "^12.6.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.8.3"
  }
}
