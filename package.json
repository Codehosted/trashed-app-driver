{
  "name": "trashed-app-for-drivers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/*.test.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:sync:ios": "npm run build && TRASHED_WEB_URL=${TRASHED_WEB_URL:-https://trashed.app} npx cap sync ios",
    "cap:sync:ios:dev": "npm run build && TRASHED_WEB_URL=${TRASHED_WEB_URL:-https://preview.trashed.app} npx cap sync ios",
    "android:install:device": "bash scripts/install-android-device.sh",
    "android:open": "npx cap open android",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.6.6",
    "@capacitor/push-notifications": "^7.0.7",
    "@google/genai": "^1.31.0",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.4.1"
  }
}
