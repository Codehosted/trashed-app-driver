# Local-only driver app configuration. Copy to .env.local for Vite/Capacitor dev builds.
# No secrets are required here.
VITE_TRASHED_WEB_BASE_URL=http://localhost:3000

# Optional: default route UUID for local driver beacon testing.
# You can also pass ?routeUuid=<uuid> in the app URL instead.
VITE_TRASHED_DRIVER_ROUTE_UUID=
VITE_DEFAULT_DRIVER_ROUTE_UUID=
